# FLOW_IGNORE_INIT_ERROR=true|false
# FLOW_WAIT_CONFIRM=true|false
# FLOW_MAX_ATTEMPTS=3
# FLOW_RETRY_DELAY_MS=800
# FLOW_POST_TX_DELAY_MS=250

