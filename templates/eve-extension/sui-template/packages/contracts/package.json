{
  "name": "contracts",
  "version": "1.0.0",
  "scripts": {
    "account:gen": "pnpm dubhe generate-key",
    "build:move": "pnpm run schemagen && cd src/eve_extension && sui move build -e testnet",
    "check-balance": "pnpm dubhe check-balance --network",
    "config:store": "pnpm dubhe config-store --output-ts-path ../ts-scripts/src/deployment.ts --network",
    "deploy": "pnpm dubhe publish --network",
    "faucet": "pnpm dubhe faucet --network",
    "schemagen": "pnpm dubhe schemagen",
    "setup:localnet": "pnpm run account:gen && pnpm run faucet localnet && pnpm run deploy localnet && pnpm run config:store localnet",
    "test:move": "pnpm run schemagen && cd src/eve_extension && sui move test -e testnet",
    "upgrade": "pnpm dubhe upgrade --network"
  },
  "dependencies": {
    "@0xobelisk/sui-cli": "link:../../../../../packages/sui-cli",
    "@0xobelisk/sui-client": "link:../../../../../packages/sui-client",
    "@0xobelisk/sui-common": "link:../../../../../packages/sui-common",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^18",
    "typescript": "^5"
  }
}
