{
  "name": "contracts",
  "version": "1.0.0",
  "scripts": {
    "// Debug Website Flow": "----------------",
    "// Development Environment": "----------------",
    "// Production Environment": "----------------",
    "// Utility Commands": "----------------",
    "account:gen": "./scripts/dubhe-local.sh generate-key",
    "check-balance": "./scripts/dubhe-local.sh check-balance --network",
    "config:store": "./scripts/dubhe-local.sh config-store --output-ts-path ./deployment.ts --network",
    "debug:collect:once": "./scripts/dubhe-local.sh debug --trace --gas-limit 500000000 --session-out .reports/move/debug-session.json --session-html-out .reports/move/debug-session.html --replay-script-out .reports/move/debug-replay.sh || true && ./scripts/dubhe-local.sh test --trace --gas-limit 500000000 --profile-gas --profile-source-map-out .reports/move/gas-source-map.json --profile-html-out .reports/move/gas-profile.html --profile-flamegraph-out .reports/move/gas-flamegraph.svg --profile-fail-on-regression false",
    "debug:collect:watch": "pnpm run debug:collect:once && chokidar \"src/**/*.move\" \"dubhe.config.ts\" -i \"**/.reports/**\" -c \"pnpm run debug:collect:once\"",
    "debug:open": "./scripts/dubhe-local.sh debug-open --open true --start-debug false",
    "debug:tui": "./scripts/dubhe-local.sh debug-tui",
    "debug:web:build": "./scripts/dubhe-local.sh workbench --strict-files false --out .reports/move/workbench.html",
    "debug:web:serve": "python3 -m http.server 4173 --directory .reports/move",
    "debug:web:watch": "while true; do pnpm run debug:web:build; sleep 2; done",
    "deploy": "./scripts/dubhe-local.sh publish --network",
    "dubhe:local": "./scripts/dubhe-local.sh",
    "faucet": "./scripts/dubhe-local.sh faucet --network",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "graphql": "docker-compose up --remove-orphans",
    "indexer": "dubhe-indexer --database-url postgres://postgres:postgres@localhost:5432/postgres --checkpoint-url .chk --config-json dubhe.config.json",
    "indexer:mainnet": "dubhe-indexer --database-url postgres://postgres:postgres@localhost:5432/postgres --checkpoint-url https://checkpoints.mainnet.sui.io --config-json dubhe.config.json",
    "indexer:testnet": "dubhe-indexer --database-url postgres://postgres:postgres@localhost:5432/postgres --checkpoint-url https://checkpoints.testnet.sui.io --config-json dubhe.config.json",
    "prod:localnet": "pnpm config:store localnet && pnpm run indexer",
    "prod:mainnet": "pnpm config:store mainnet && pnpm run indexer:mainnet",
    "prod:testnet": "pnpm config:store testnet && pnpm run indexer:testnet",
    "schemagen": "./scripts/dubhe-local.sh schemagen",
    "setup:localnet": "pnpm account:gen && pnpm faucet localnet && pnpm run deploy localnet && pnpm run config:store localnet && pnpm run indexer --force",
    "setup:mainnet": "pnpm account:gen && pnpm check-balance mainnet && pnpm run deploy mainnet && pnpm run config:store mainnet && pnpm run indexer:mainnet --force",
    "setup:testnet": "pnpm account:gen && pnpm check-balance testnet && pnpm run deploy testnet && pnpm run config:store testnet && pnpm run indexer:testnet --force",
    "start:localnet": "./scripts/dubhe-local.sh node",
    "type-check": "tsc --noEmit",
    "upgrade": "./scripts/dubhe-local.sh upgrade --network",
    "validate": "pnpm format:check && pnpm type-check"
  },
  "dependencies": {
    "@0xobelisk/sui-client": "link:../../../../../packages/sui-client",
    "@0xobelisk/sui-common": "link:../../../../../packages/sui-common",
    "dotenv": "^16.4.5",
    "sonner": "^1.5.0",
    "viem": "2.21.19"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^18",
    "chokidar-cli": "^3.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "mprocs": "^0.7.1",
    "postcss": "^8",
    "prettier": "3.3.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wait-on": "^8.0.3"
  }
}
